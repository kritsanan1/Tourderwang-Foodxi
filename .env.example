
# Tourderwang Food Delivery - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Your Supabase project URL
# Find this in your Supabase project dashboard under Settings > API
# Format: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://oeotqlircqmuvhfayrhw.supabase.co

# Supabase anonymous public key
# This key is safe to use in client-side code
# Find this in your Supabase project dashboard under Settings > API
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9lb3RxbGlyY3FtdXZoZmF5cmh3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTM0MzMzNTcsImV4cCI6MjA2OTAwOTM1N30.gQWn_Gy0_5UpKL2OdmOalQK7ORSaQ2OG1d-nkeaA1Yo

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application environment (development, staging, production)
VITE_APP_ENV=development

# Application title for browser tab and meta tags
VITE_APP_TITLE="Tourderwang - Food Delivery"

# Base URL for the application (used for routing and API calls)
VITE_APP_BASE_URL=http://localhost:5000

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION (Optional)
# =============================================================================
# Thai payment gateway configuration
# Uncomment and configure when payment integration is implemented

# VITE_PAYMENT_GATEWAY_URL=https://api.payment-provider.com
# VITE_PAYMENT_PUBLIC_KEY=your_payment_public_key
# VITE_PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# GOOGLE SERVICES (Optional)
# =============================================================================
# Google Maps API key for delivery tracking and restaurant locations
# Get from: https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Analytics tracking ID for user analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# Email service configuration for order confirmations
# Supabase handles auth emails, but you might want custom transactional emails
# VITE_EMAIL_SERVICE_URL=https://api.emailservice.com
# VITE_EMAIL_API_KEY=your_email_api_key

# =============================================================================
# SMS CONFIGURATION (Optional)
# =============================================================================
# SMS service for order notifications (Thai SMS providers)
# VITE_SMS_PROVIDER_URL=https://api.sms-provider.com
# VITE_SMS_API_KEY=your_sms_api_key

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Enable debug mode for development (shows additional console logs)
VITE_DEBUG=false

# Enable React Query devtools in development
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Enable detailed error reporting
VITE_ENABLE_ERROR_REPORTING=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT secret for additional client-side token validation (optional)
# VITE_JWT_SECRET=your_jwt_secret_for_client_validation

# CORS origins for API requests (comma-separated list)
VITE_ALLOWED_ORIGINS=http://localhost:5000,https://your-domain.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features for different environments
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_REAL_TIME_TRACKING=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_PUSH_NOTIFICATIONS=false

# =============================================================================
# LOCALIZATION
# =============================================================================
# Default language for the application
VITE_DEFAULT_LANGUAGE=th

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=th,en

# =============================================================================
# PERFORMANCE & MONITORING
# =============================================================================
# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Performance monitoring endpoint
# VITE_PERFORMANCE_API_URL=https://your-performance-monitoring.com

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit the actual .env file to version control
# 2. All VITE_ prefixed variables are exposed to the client-side code
# 3. Keep sensitive data in Supabase vault or server-side environment variables
# 4. For production deployment, set these variables in your hosting platform
# 5. Test all integrations in development before deploying to production

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================
# These variables might be set automatically by your deployment platform

# Build command override (if needed)
# BUILD_COMMAND=npm run build

# Install command override (if needed)  
# INSTALL_COMMAND=npm install

# Node.js version specification
# NODE_VERSION=18

# Package manager preference
# PACKAGE_MANAGER=npm
